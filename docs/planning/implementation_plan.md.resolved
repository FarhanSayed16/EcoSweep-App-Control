                last_garbage_time = now
                last_no_garbage_time = 0.0
                last_valid_detection_time = now
                last_seen_bbox_area = bbox_area
                last_centered_bbox_area = bbox_area if is_centered else 0
                last_front_for_stuck = front_ok
                stuck_since = now
